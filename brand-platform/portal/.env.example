# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (for invite links and email redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: skip email verification in local dev
# SKIP_EMAIL_VERIFICATION=true

# QR rewards (Phase 5) — generate with: openssl rand -base64 32
REWARD_TOKEN_ENCRYPTION_KEY=your-32-byte-base64-key
REDEEM_BASE_URL=https://redeem.cada.app
QR_TTL_HOURS=24

# Cron job auth for expire-rewards endpoint
CRON_SECRET=your-cron-secret

# Phase 8 — marketing site bridge
# Comma-separated origins allowed to POST /api/leads (include file:// preview as null)
MARKETING_SITE_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,null,https://cada.app

# Internal token for /admin/leads and GET/PATCH /api/admin/leads
LEADS_ADMIN_TOKEN=your-leads-admin-token

# Internal token for /admin/challenges and POST /api/admin/challenges/*
CADA_ADMIN_TOKEN=your-cada-admin-token
