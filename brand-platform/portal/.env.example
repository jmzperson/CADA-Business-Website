# QR rewards (Phase 5) — generate with: openssl rand -base64 32
REWARD_TOKEN_ENCRYPTION_KEY=your-32-byte-base64-key
REDEEM_BASE_URL=https://redeem.cada.app
QR_TTL_HOURS=24

# Cron job auth for expire-rewards and expire-challenges endpoints
CRON_SECRET=your-cron-secret

# Phase 8 — marketing site bridge
# Comma-separated origins allowed to POST /api/leads (marketing site)
MARKETING_SITE_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,null,https://cadaapp.com,https://www.cadaapp.com

# Internal token for /admin/leads and GET/PATCH /api/admin/leads
LEADS_ADMIN_TOKEN=your-leads-admin-token

# Internal token for /admin/challenges and POST /api/admin/challenges/*
CADA_ADMIN_TOKEN=your-cada-admin-token

# Challenge review notifications (Resend → james@cadaapp.com)
CHALLENGE_NOTIFY_EMAIL=james@cadaapp.com
RESEND_API_KEY=re_xxxxxxxx
# Use a verified domain in Resend (e.g. notifications@cadaapp.com)
RESEND_FROM=CADA Partners <notifications@cadaapp.com>
